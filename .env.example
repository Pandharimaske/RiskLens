# DVC Remote Configuration
# Uncomment and update with your DagsHub credentials

# DAGSHUB_USERNAME=your_username
# DAGSHUB_TOKEN=your_dagshub_token
# DAGSHUB_PASSWORD=your_dagshub_token

# AWS Credentials (for deployment)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=ap-south-1
# ECR_REGISTRY=your_ecr_registry

# MLflow Configuration
# MLFLOW_TRACKING_URI=https://dagshub.com/USERNAME/risklens.mlflow
# MLFLOW_TRACKING_USERNAME=your_username
# MLFLOW_TRACKING_PASSWORD=your_token

# EC2 Deployment
# EC2_HOST=your_ec2_public_ip
# EC2_SSH_KEY=path_to_ssh_key
