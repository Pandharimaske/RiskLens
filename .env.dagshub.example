# DagsHub MLflow Environment Configuration Template
# IMPORTANT: Copy this file to .env.dagshub and fill in your credentials
# DO NOT commit .env.dagshub to version control!

export DAGSHUB_USERNAME=your_dagshub_username
export DAGSHUB_TOKEN=your_dagshub_token_from_settings
export MLFLOW_TRACKING_URI=https://your_username:your_token@dagshub.com/your_username/RiskLens.mlflow
export MLFLOW_TRACKING_USERNAME=your_dagshub_username
export MLFLOW_TRACKING_PASSWORD=your_dagshub_token_from_settings
